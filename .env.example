# ── LLM Provider: tongyi | deepseek | zhipu ──────────────────
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_MODEL_CHEAP=deepseek-chat

# ── API Keys ──────────────────────────────────────────────────
TONGYI_API_KEY=sk-your-key-here
DEEPSEEK_API_KEY=sk-your-key-here
ZHIPU_API_KEY=your-key-here

# ── Embedding (推荐通义) ─────────────────────────────────────
EMBEDDING_PROVIDER=tongyi
TONGYI_EMBEDDING_MODEL=text-embedding-v3

# ── Retrieval ─────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5

# ── Chunking ──────────────────────────────────────────────────
CHILD_CHUNK_SIZE=200
CHILD_CHUNK_OVERLAP=50
PARENT_CHUNK_SIZE=800
PARENT_CHUNK_OVERLAP=25

# ── Reranker ──────────────────────────────────────────────────
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
